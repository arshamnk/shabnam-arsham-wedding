rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedInAndVerified() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isSignedInUser(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isBlocked(userId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/blockedUsers/$(userId));
    }

    function canUseSite() {
      return signedInAndVerified() && !isBlocked(request.auth.uid);
    }

    function isBootstrapAdmin() {
      return canUseSite()
        && request.auth.token.email == 'antiret@gmail.com';
    }

    function isCurrentUser(userId) {
      return canUseSite() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isBootstrapAdmin() ||
        (canUseSite() &&
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    function keepsIdentityStable() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email;
    }

    function isGuestRsvpWrite(userId) {
      return isCurrentUser(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email;
    }

    function isAdminDonationUpdate() {
      return isAdmin()
        && keepsIdentityStable()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'donationAmount',
          'donationUpdatedAt'
        ]);
    }

    function isProfileWrite(userId) {
      return isCurrentUser(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.emailVerified == true;
    }

    function isAdminGrantWrite(userId) {
      return isAdmin()
        && request.resource.data.uid == userId;
    }

    match /admins/{userId} {
      allow get: if isAdmin() || isCurrentUser(userId);
      allow list: if isAdmin();
      allow create, update: if isAdminGrantWrite(userId);
      allow delete: if isAdmin();
    }

    match /profiles/{userId} {
      allow get: if isAdmin() || isCurrentUser(userId);
      allow list: if isAdmin();
      allow create, update: if isProfileWrite(userId);
      allow delete: if false;
    }

    match /blockedUsers/{userId} {
      allow get: if isAdmin() || isSignedInUser(userId);
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /rsvps/{userId} {
      allow get: if isAdmin() || isCurrentUser(userId);
      allow list: if isAdmin();
      allow create: if isGuestRsvpWrite(userId);
      allow update: if isAdminDonationUpdate();
      allow delete: if isAdmin();
    }
  }
}
